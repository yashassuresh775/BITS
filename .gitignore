# Python
.venv/
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
dist/
build/

# Streamlit local secrets (use Cloud UI or secrets.toml.example)
.streamlit/secrets.toml

# OS / IDE
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Secrets & local env (never commit)
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials.json
*credentials*.json

# Hackathon data (large + distribution-sensitive)
data/student-pack/*
!data/student-pack/.gitkeep
!data/student-pack/docs/
!data/student-pack/docs/edgar_starter_snippet.md

# Equity pack CSVs (copy from student-pack locally; keep README only)
data/equity-data/*
!data/equity-data/README.txt

# Binance backfill (large; regenerate with scripts/fetch_binance_history.py)
data/binance-hist/*
!data/binance-hist/.gitkeep

# Generated outputs
p1_alerts.csv
p2_signals.csv
submission.csv
submission_offline.csv
submission_live.csv
submission_from_binance.csv
*.submission.csv
