# Copy these keys into Streamlit Community Cloud: App → Settings → Secrets.
# Do not commit real `secrets.toml` (it is gitignored).

# Optional: HTTPS URL to a raw CSV (e.g. a gist raw link or public S3 object).
# Must return the same columns as submission.csv (symbol, date, trade_id, violation_type, remarks).
# PRIMARY_SUBMISSION_URL = "https://example.com/submission.csv"

# Optional second file for the P3 compare sub-tabs.
# SECOND_SUBMISSION_URL = "https://example.com/submission_live.csv"

# P1 / P2 dashboard tabs (optional raw CSV URLs).
# P1_ALERTS_URL = "https://example.com/p1_alerts.csv"
# P2_SIGNALS_URL = "https://example.com/p2_signals.csv"

# P1 tab — Live (poll CSV URLs): optional defaults for the URL fields.
# P1_LIVE_MARKET_URL = "https://example.com/market_data.csv"
# P1_LIVE_TRADE_URL = "https://example.com/trade_data.csv"

# Live pipeline venue (same as env):
#   okx (default) | binance | both  (aliases: okx+binance, binance+okx)
# LIVE_SPOT_VENUE = "binance"
# LIVE_SPOT_VENUE = "both"
# BINANCE_SPOT_API = "https://api.binance.us/api/v3"
